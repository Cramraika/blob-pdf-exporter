{
  "manifest_version": 3,
  "name": "Blob PDF Exporter",
  "short_name": "Blob PDF",
  "version": "0.1.2",
  "description": "Combine blob: images on the current page into a single PDF. Useful for document viewers that render pages as blob URLs.",
  "author": "Chinmay Ramraika / Vagary Labs",
  "homepage_url": "https://github.com/Cramraika/blob-pdf-exporter",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Blob PDF Exporter",
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "vendor/jspdf.umd.min.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
